      <!-- Dynamic Insights Cards -->
      <section class="space-y-6">
        <h3 class="text-xs text-indigo-400 font-bold uppercase tracking-[0.2em] font-mono">03 / Strategic Sourcing Patterns</h3>
        <div class="grid md:grid-cols-3 gap-6">
