          <input id="search" placeholder="Filter by app name, auth type, or verdict..." class="w-full bg-slate-900/40 border border-slate-800/80 rounded-xl pl-11 pr-5 py-3 text-slate-200 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition-all placeholder-slate-500" />
        </div>
        <select id="categoryFilter" class="bg-slate-900/40 border border-slate-800/80 rounded-xl px-5 py-3 text-slate-200 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition-all appearance-none pr-10 cursor-pointer" style="background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%2394a3b8%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 1rem top 50%; background-size: 0.65rem auto;"></select>
        <select id="confidenceFilter" class="bg-slate-900/40 border border-slate-800/80 rounded-xl px-5 py-3 text-slate-200 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition-all appearance-none pr-10 cursor-pointer" style="background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%2394a3b8%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 1rem top 50%; background-size: 0.65rem auto;">
          <option value="">All confidence</option>
          <option value="HIGH">HIGH</option>
          <option value="MEDIUM">MEDIUM</option>
          <option value="LOW">LOW</option>
        </select>
      </div>

      <!-- Audit Sourcing Table -->
      <div class="neo-card rounded-2xl overflow-hidden">
        <div class="overflow-x-auto h-[70vh]">
          <table class="w-full text-sm min-w-[1200px] border-collapse text-left">
            <thead>
              <tr class="bg-slate-950">
                <th class="sticky top-0 bg-slate-950/90 backdrop-blur-md z-10 text-[10px] font-bold text-slate-500 uppercase tracking-wider text-left p-4 border-b border-slate-900">APP</th>
                <th class="sticky top-0 bg-slate-950/90 backdrop-blur-md z-10 text-[10px] font-bold text-slate-500 uppercase tracking-wider text-left p-4 border-b border-slate-900">DESCRIPTION</th>
                <th class="sticky top-0 bg-slate-950/90 backdrop-blur-md z-10 text-[10px] font-bold text-slate-500 uppercase tracking-wider text-left p-4 border-b border-slate-900">AUTH</th>
                <th class="sticky top-0 bg-slate-950/90 backdrop-blur-md z-10 text-[10px] font-bold text-slate-500 uppercase tracking-wider text-left p-4 border-b border-slate-900">ACCESS</th>
                <th class="sticky top-0 bg-slate-950/90 backdrop-blur-md z-10 text-[10px] font-bold text-slate-500 uppercase tracking-wider text-left p-4 border-b border-slate-900">API SURFACE</th>
                <th class="sticky top-0 bg-slate-950/90 backdrop-blur-md z-10 text-[10px] font-bold text-slate-500 uppercase tracking-wider text-left p-4 border-b border-slate-900 text-center">MCP</th>
                <th class="sticky top-0 bg-slate-950/90 backdrop-blur-md z-10 text-[10px] font-bold text-slate-500 uppercase tracking-wider text-left p-4 border-b border-slate-900 text-center">COMPOSIO</th>
                <th class="sticky top-0 bg-slate-950/90 backdrop-blur-md z-10 text-[10px] font-bold text-slate-500 uppercase tracking-wider text-left p-4 border-b border-slate-900">VERDICT</th>
                <th class="sticky top-0 bg-slate-950/90 backdrop-blur-md z-10 text-[10px] font-bold text-slate-500 uppercase tracking-wider text-left p-4 border-b border-slate-900 text-center">CONFIDENCE</th>
                <th class="sticky top-0 bg-slate-950/90 backdrop-blur-md z-10 text-[10px] font-bold text-slate-500 uppercase tracking-wider text-right p-4 border-b border-slate-900">EVIDENCE</th>
              </tr>
            </thead>
            <tbody id="rows" class="divide-y divide-slate-900"></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Main Footer -->
    <footer class="text-center py-6 border-t border-slate-900 text-slate-500 text-xs">
      <p class="font-semibold font-mono">SaaS Toolkit & Integration Audit &middot; MasterJi27 &middot; AI Product Ops</p>
      <p class="mt-2 text-slate-600">Generated dynamically using Gemini Flash 1.5, Composio MCP, and multi-agent pipeline routing.</p>
    </footer>

  </main>

  <!-- Navigation Switch Tab Script -->
  <script>
    function switchTab(tabId) {
      document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
      document.getElementById(tabId).classList.remove('hidden');
      
      document.querySelectorAll('.sidebar-btn').forEach(el => el.classList.remove('active'));
      document.getElementById('btn-' + tabId).classList.add('active');
    }
  </script>

  <!-- Sourcing Sorter Script -->
  <script>
    const ROWS = {{ rows_json|safe }};
    const STATS = {{ stats_json|safe }};
    const esc = s => String(s ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]);

    // Populate KPIs
    document.getElementById('kpi-total').textContent = ROWS.length;
    document.getElementById('kpi-high').textContent = STATS.high_confidence || 0;
    document.getElementById('kpi-tools').textContent = STATS.composio_total_tools || 0;
    document.getElementById('kpi-supported').textContent = STATS.composio_supported || 0;
    document.getElementById('kpi-toolkits').textContent = ROWS.filter(r=>r.composio_tools>0).length;
    document.getElementById('kpi-self').textContent = ROWS.filter(r=>/self-serve|free|trial/i.test(r.access)&&!/enterprise|gate|paid.*only|contract|admin/i.test(r.access)).length;

    // Populate category filter
    const cats = [...new Set(ROWS.map(r=>r.category))];
    const catSelect = document.getElementById('categoryFilter');
    catSelect.innerHTML = '<option value="">All categories</option>' + cats.map(c => '<option value="'+esc(c)+'">'+esc(c)+'</option>').join('');

    // Table render
    function render() {
      const q = document.getElementById('search').value.toLowerCase().trim();
      const cat = document.getElementById('categoryFilter').value;
      const cf = document.getElementById('confidenceFilter').value;
      const filtered = ROWS.filter(r => {
        const blob = [r.app,r.category,r.description,r.auth,r.access,r.api,r.verdict].join(' ').toLowerCase();
        return (!q||blob.includes(q)) && (!cat||r.category===cat) && (!cf||(r.confidence||'LOW')===cf);
      });
      document.getElementById('rows').innerHTML = filtered.map(r => {
        const ev = r.evidence ? '<a class="text-indigo-400 hover:text-indigo-300 hover:underline font-semibold font-mono" href="'+esc(r.evidence)+'" target="_blank">Docs &nearr;</a>' : '';
        const mc = r.mcp && /mcp/i.test(r.mcp) && !/no/i.test(r.mcp) ? '<span class="badge badge-purple">MCP</span>' : '';
        const vk = /^Low/i.test(r.verdict) ? 'badge-red' : /^Medium/i.test(r.verdict) ? 'badge-amber' : 'badge-green';
        const ck = r.confidence === 'HIGH' ? 'badge-green' : r.confidence === 'MEDIUM' ? 'badge-amber' : 'badge-red';
        const cs = r.composio_supported ? '<span class="text-emerald-400 font-bold font-mono">&check; '+ (r.composio_tools||'') +' tools</span>' : '<span class="text-slate-500 font-mono">&mdash;</span>';
        return '<tr class="hover:bg-slate-900/30 transition-colors">' +
          '<td class="px-5 py-4"><div class="font-bold text-white tracking-tight">'+esc(r.app)+'</div><div class="text-[10px] text-slate-500 font-bold uppercase tracking-wider font-mono mt-1">'+esc(r.category)+'</div></td>'+
          '<td class="px-5 py-4 text-slate-400 max-w-xs leading-relaxed" title="'+esc(r.description||'')+'">'+esc(r.description||'')+'</td>'+
          '<td class="px-5 py-4 font-semibold font-mono text-slate-300">'+esc(r.auth)+'</td>'+
          '<td class="px-5 py-4 text-slate-300">'+esc(r.access)+'</td>'+
          '<td class="px-5 py-4 font-mono text-[12px] text-slate-400">'+esc(r.api)+'</td>'+
          '<td class="px-5 py-4 text-center">'+mc+'</td>'+
          '<td class="px-5 py-4 text-center">'+cs+'</td>'+
          '<td class="px-5 py-4"><span class="badge '+vk+'">'+esc(r.verdict).substring(0,35)+'</span></td>'+
          '<td class="px-5 py-4 text-center"><span class="badge '+ck+'">'+r.confidence+'</span></td>'+
          '<td class="px-5 py-4 text-right">'+ev+'</td>'+
        '</tr>';
      }).join('');
    }
    ['search','categoryFilter','confidenceFilter'].forEach(id => document.getElementById(id).addEventListener('input', render));
    render();
  </script>
</body>
</html>
